{
  "$schema": "./src/shared/configs/agent-schema.json",
  "version": "1.0.0",
  "lastUpdated": "2026-04-17",
  "domains": {
    "security": {
      "path": "src/agents/security",
      "description": "Security auditing and vulnerability detection",
      "agents": ["security-auditor"]
    },
    "documentation": {
      "path": "src/agents/documentation",
      "description": "Documentation generation and maintenance",
      "agents": ["docs-writer"]
    },
    "code-review": {
      "path": "src/agents/code-review",
      "description": "Code quality, SDD compliance and best practices review",
      "agents": ["sdd-compliance", "code-reviewer"]
    },
    "planning": {
      "path": "src/agents/planning",
      "description": "Requirements analysis and architecture planning",
      "agents": ["architect", "requirements-analyzer"]
    },
    "coding": {
      "path": "src/agents/coding",
      "description": "Code generation and test creation",
      "agents": ["code-generator", "test-generator"]
    },
    "debug": {
      "path": "src/agents/debug",
      "description": "Debugging and investigation",
      "agents": []
    },
    "exploration": {
      "path": "src/agents/exploration",
      "description": "Codebase exploration and search",
      "agents": []
    },
    "creation": {
      "path": "src/agents/creation",
      "description": "Agent and team creation following repository methodology",
      "agents": ["agent-builder"]
    },
    "teams": {
      "path": "src/agents/teams",
      "description": "Pre-configured agent teams with team leaders",
      "agents": []
    }
  },
  "teams": {
    "saas": {
      "path": "src/agents/teams/saas",
      "team_leader": "saas-project-generator",
      "team_file": "saas.team.md",
      "description": "Complete SaaS project development team",
      "agents": ["architect", "requirements-analyzer", "code-generator", "test-generator", "sdd-compliance"]
    },
    "team-builder": {
      "path": "src/agents/teams/team-builder",
      "team_leader": "team-builder",
      "team_file": "team-builder.team.md",
      "description": "Meta-team that creates new agent teams",
      "agents": ["agent-builder", "architect", "docs-writer"]
    }
  },
  "shared": {
    "prompts": "src/shared/prompts",
    "configs": "src/shared/configs"
  }
}
